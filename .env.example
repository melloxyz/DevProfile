# Publica (nao sensivel)
NEXT_PUBLIC_GITHUB_USERNAME=
# URL canonica da aplicacao (ex: https://seu-dominio.com)
NEXT_PUBLIC_SITE_URL=

# Server-only (nunca use NEXT_PUBLIC_ para segredos)
GITHUB_TOKEN=
ADMIN_ROUTE_SLUG=
# Use hash bcrypt. Em .env, escape "$" como "\$" para evitar expansao de variavel.
# Exemplo de formato: $2a$12$nVzDji7sx.Cd..DCJicy1.uOGobCCuo8fwvNujQX6mhicEq94OcLG
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
KV_REST_API_URL=
KV_REST_API_TOKEN=
